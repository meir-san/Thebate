<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Debate Overlay</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: rgba(5, 8, 15, 0.88);
    --border: rgba(255,255,255,0.07);
    --text: #e2e8f0;
    --text-dim: #94a3b8;
    --blue: #3b82f6;
    --orange: #f97316;
    --green: #22c55e;
    --yellow: #eab308;
    --red: #ef4444;
    --purple: #a855f7;
  }
  html, body {
    width: 1920px;
    height: 1080px;
    overflow: hidden;
    background: transparent;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
  }

  /* Speaker Cards */
  .speaker-card {
    position: absolute;
    top: 24px;
    width: 340px;
    background: var(--bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    padding: 24px;
    border: 1px solid var(--border);
  }
  .speaker-card.left {
    left: 24px;
    border-left: 3px solid var(--blue);
    border-radius: 0 12px 12px 0;
  }
  .speaker-card.right {
    right: 24px;
    border-right: 3px solid var(--orange);
    border-radius: 12px 0 0 12px;
  }
  .card-name { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 12px; }
  .card-score { font-family: 'Syne', sans-serif; font-size: 56px; font-weight: 800; line-height: 1; margin-bottom: 20px; }
  .card-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .card-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-dim); width: 100px; flex-shrink: 0; }
  .card-bar { flex: 1; height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; }
  .card-bar-fill { height: 100%; border-radius: 2px; }
  .card-value { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-dim); width: 36px; text-align: right; flex-shrink: 0; }
  .card-footer { margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--border); font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-dim); }

  /* Bottom Bar */
  .bottom-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 112px;
    background: rgba(5, 8, 15, 0.95);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .brand-strip {
    height: 26px;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 24px;
    border-bottom: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
  }
  .brand-strip-name { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 10px; letter-spacing: 2px; color: var(--text); }
  .pulse-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--red);
    animation: pulse 2s infinite;
    display: inline-block;
    margin-right: 4px;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  .bottom-main {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 0 24px;
    gap: 20px;
  }

  /* Timeline in bottom bar */
  .bottom-timeline { flex: 1; min-width: 0; }
  .bt-legend { display: flex; gap: 12px; margin-bottom: 6px; font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text-dim); }
  .bt-legend-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-right: 3px; vertical-align: middle; }
  .bt-track-wrap { position: relative; }
  .bt-track { height: 16px; display: flex; border-radius: 3px; overflow: hidden; background: rgba(255,255,255,0.03); }
  .bt-segment { height: 100%; min-width: 1px; }
  .bt-flags { position: relative; height: 10px; }
  .bt-flag-dot { position: absolute; width: 5px; height: 5px; border-radius: 50%; top: 2px; transform: translateX(-2px); }
  .bt-flag-dot.dodge { background: var(--red); }
  .bt-flag-dot.low_engagement { background: var(--yellow); }
  .bt-flag-dot.topic_drift { background: var(--purple); }
  .bt-axis { display: flex; justify-content: space-between; font-family: 'JetBrains Mono', monospace; font-size: 8px; color: var(--text-dim); margin-top: 2px; }

  /* Latest Flag Panel */
  .latest-flag-panel {
    width: 420px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    overflow: hidden;
  }
  .lfp-header { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .lfp-badge { font-family: 'JetBrains Mono', monospace; font-size: 9px; padding: 1px 6px; border-radius: 3px; text-transform: uppercase; letter-spacing: 1px; }
  .lfp-badge.dodge { background: rgba(239,68,68,0.15); color: var(--red); }
  .lfp-badge.low_engagement { background: rgba(234,179,8,0.15); color: var(--yellow); }
  .lfp-badge.topic_drift { background: rgba(168,85,247,0.15); color: var(--purple); }
  .lfp-speaker { font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 600; }
  .lfp-explanation { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text-dim); margin-bottom: 4px; line-height: 1.4; }
  .lfp-quote { font-style: italic; font-size: 10px; color: var(--text-dim); line-height: 1.3; }

  /* Score Comparison */
  .score-compare {
    width: 300px;
    flex-shrink: 0;
  }
  .sc-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .sc-name { font-family: 'JetBrains Mono', monospace; font-size: 10px; width: 90px; text-align: right; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .sc-bar { flex: 1; height: 14px; background: rgba(255,255,255,0.04); border-radius: 3px; overflow: hidden; position: relative; }
  .sc-bar-fill { height: 100%; border-radius: 3px; }
  .sc-score { position: absolute; right: 6px; top: 50%; transform: translateY(-50%); font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700; }
  .sc-formula { font-family: 'JetBrains Mono', monospace; font-size: 7px; color: var(--text-dim); line-height: 1.3; margin-top: 4px; }
</style>
</head>
<body>

{% if speakers | length >= 1 and speakers[0] in stats %}
{% set sa = stats[speakers[0]] %}
<!-- Speaker A Card (top-left) -->
<div class="speaker-card left">
  <div class="card-name" style="color: var(--blue);">{{ speakers[0] }}</div>
  <div class="card-score" style="color: {{ sa.overall_score | score_color }};">{{ sa.overall_score }}</div>
  <div class="card-row">
    <span class="card-label">Engagement</span>
    <div class="card-bar"><div class="card-bar-fill" style="width: {{ (sa.avg_engagement * 100)|round(0) }}%; background: var(--blue);"></div></div>
    <span class="card-value">{{ '%.0f' | format(sa.avg_engagement * 100) }}%</span>
  </div>
  <div class="card-row">
    <span class="card-label">Dodge Rate</span>
    <div class="card-bar"><div class="card-bar-fill" style="width: {{ ((1 - sa.dodge_rate) * 100)|round(0) }}%; background: var(--blue);"></div></div>
    <span class="card-value">{{ '%.0f' | format(sa.dodge_rate * 100) }}%</span>
  </div>
  <div class="card-row">
    <span class="card-label">Claim Support</span>
    <div class="card-bar"><div class="card-bar-fill" style="width: {{ (sa.claim_support_ratio * 100)|round(0) }}%; background: var(--blue);"></div></div>
    <span class="card-value">{{ '%.0f' | format(sa.claim_support_ratio * 100) }}%</span>
  </div>
  <div class="card-row">
    <span class="card-label">Topic Focus</span>
    <div class="card-bar"><div class="card-bar-fill" style="width: {{ ((1 - sa.avg_topic_drift) * 100)|round(0) }}%; background: var(--blue);"></div></div>
    <span class="card-value">{{ '%.0f' | format((1 - sa.avg_topic_drift) * 100) }}%</span>
  </div>
  <div class="card-footer">
    {% set fc_a = [] %}{% for t in turns if t.speaker == speakers[0] %}{% for f in t.flags %}{% if fc_a.append(1) %}{% endif %}{% endfor %}{% endfor %}
    Flags raised: {{ fc_a | length }} events
  </div>
</div>
{% endif %}

{% if speakers | length >= 2 and speakers[1] in stats %}
{% set sb = stats[speakers[1]] %}
<!-- Speaker B Card (top-right) -->
<div class="speaker-card right">
  <div class="card-name" style="color: var(--orange);">{{ speakers[1] }}</div>
  <div class="card-score" style="color: {{ sb.overall_score | score_color }};">{{ sb.overall_score }}</div>
  <div class="card-row">
    <span class="card-label">Engagement</span>
    <div class="card-bar"><div class="card-bar-fill" style="width: {{ (sb.avg_engagement * 100)|round(0) }}%; background: var(--orange);"></div></div>
    <span class="card-value">{{ '%.0f' | format(sb.avg_engagement * 100) }}%</span>
  </div>
  <div class="card-row">
    <span class="card-label">Dodge Rate</span>
    <div class="card-bar"><div class="card-bar-fill" style="width: {{ ((1 - sb.dodge_rate) * 100)|round(0) }}%; background: var(--orange);"></div></div>
    <span class="card-value">{{ '%.0f' | format(sb.dodge_rate * 100) }}%</span>
  </div>
  <div class="card-row">
    <span class="card-label">Claim Support</span>
    <div class="card-bar"><div class="card-bar-fill" style="width: {{ (sb.claim_support_ratio * 100)|round(0) }}%; background: var(--orange);"></div></div>
    <span class="card-value">{{ '%.0f' | format(sb.claim_support_ratio * 100) }}%</span>
  </div>
  <div class="card-row">
    <span class="card-label">Topic Focus</span>
    <div class="card-bar"><div class="card-bar-fill" style="width: {{ ((1 - sb.avg_topic_drift) * 100)|round(0) }}%; background: var(--orange);"></div></div>
    <span class="card-value">{{ '%.0f' | format((1 - sb.avg_topic_drift) * 100) }}%</span>
  </div>
  <div class="card-footer">
    {% set fc_b = [] %}{% for t in turns if t.speaker == speakers[1] %}{% for f in t.flags %}{% if fc_b.append(1) %}{% endif %}{% endfor %}{% endfor %}
    Flags raised: {{ fc_b | length }} events
  </div>
</div>
{% endif %}

<!-- Bottom Bar -->
<div class="bottom-bar">
  <div class="brand-strip">
    <span class="brand-strip-name">DEBATESTATS</span>
    <span>{{ result.topic }}</span>
    <span style="margin-left: auto;"><span class="pulse-dot"></span>PROCESS METRICS ONLY</span>
  </div>
  <div class="bottom-main">
    <!-- Timeline -->
    <div class="bottom-timeline">
      <div class="bt-legend">
        <span><span class="bt-legend-dot" style="background: var(--blue);"></span>{{ speakers[0] if speakers | length >= 1 else '' }}</span>
        <span><span class="bt-legend-dot" style="background: var(--orange);"></span>{{ speakers[1] if speakers | length >= 2 else '' }}</span>
        <span style="margin-left: 8px;"><span class="bt-legend-dot" style="background: var(--red);"></span>Dodge</span>
        <span><span class="bt-legend-dot" style="background: var(--yellow);"></span>Engagement</span>
        <span><span class="bt-legend-dot" style="background: var(--purple);"></span>Drift</span>
        <span style="margin-left: auto; color: var(--text);">{{ result.duration_ms | ms_to_timestamp }}</span>
      </div>
      <div class="bt-track-wrap">
        <div class="bt-track">
          {% for turn in turns %}
          {% set width = ((turn.end_ms - turn.start_ms) / result.duration_ms * 100) %}
          {% set bg = 'rgba(59,130,246,0.5)' if turn.speaker == speakers[0] else 'rgba(249,115,22,0.5)' %}
          <div class="bt-segment" style="width: {{ width }}%; background: {{ bg }};"></div>
          {% endfor %}
        </div>
        <div class="bt-flags">
          {% for flag in flags %}
          {% set left = (turns_by_index[flag.turn_index].start_ms / result.duration_ms * 100) %}
          <div class="bt-flag-dot {{ flag.flag_type }}" style="left: {{ left }}%;"></div>
          {% endfor %}
        </div>
      </div>
      <div class="bt-axis">
        {% for i in range(5) %}
        <span>{{ (result.duration_ms * i / 4) | int | ms_to_timestamp }}</span>
        {% endfor %}
      </div>
    </div>

    <!-- Latest Flag Panel -->
    <div class="latest-flag-panel">
      {% if latest_flag %}
      {% set lf_color = '#3b82f6' if latest_flag_turn.speaker == speakers[0] else '#f97316' %}
      <div class="lfp-header">
        <span class="lfp-badge {{ latest_flag.flag_type }}">{{ latest_flag.flag_type | replace('_', ' ') }}</span>
        <span class="lfp-speaker" style="color: {{ lf_color }};">{{ latest_flag_turn.speaker }}</span>
      </div>
      <div class="lfp-explanation">{{ latest_flag.explanation }}</div>
      <div class="lfp-quote">"{{ latest_flag_turn.text[:80] }}{% if latest_flag_turn.text | length > 80 %}...{% endif %}"</div>
      {% else %}
      <div class="lfp-explanation">No flags raised</div>
      {% endif %}
    </div>

    <!-- Score Comparison -->
    <div class="score-compare">
      {% for speaker in speakers %}
      {% if speaker in stats %}
      {% set s = stats[speaker] %}
      {% set color = 'var(--blue)' if loop.index0 == 0 else 'var(--orange)' %}
      <div class="sc-row">
        <span class="sc-name" style="color: {{ color }};">{{ speaker }}</span>
        <div class="sc-bar">
          <div class="sc-bar-fill" style="width: {{ s.overall_score }}%; background: {{ color }};"></div>
          <span class="sc-score" style="color: {{ s.overall_score | score_color }};">{{ s.overall_score }}</span>
        </div>
      </div>
      {% endif %}
      {% endfor %}
      <div class="sc-formula">E×30 + (1−D)×25 + C×25 + (1−T)×20</div>
    </div>
  </div>
</div>

</body>
</html>
